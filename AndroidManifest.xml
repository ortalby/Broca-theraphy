package com.aphasia.broca.ui

import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.Button
import android.widget.LinearLayout
import android.widget.TextView
import androidx.fragment.app.Fragment
import com.aphasia.broca.MainActivity
import com.aphasia.broca.data.AAC_PHRASES
import com.aphasia.broca.databinding.FragmentAacBinding

class AacFragment : Fragment() {

    private var _b: FragmentAacBinding? = null
    private val b get() = _b!!
    private val tts get() = (requireActivity() as MainActivity).tts

    override fun onCreateView(inflater: LayoutInflater, container: ViewGroup?, savedInstanceState: Bundle?) =
        FragmentAacBinding.inflate(inflater, container, false).also { _b = it }.root

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        buildBoard()
    }

    private fun buildBoard() {
        val grid = b.aacGrid
        grid.removeAllViews()
        var row: LinearLayout? = null
        AAC_PHRASES.forEachIndexed { index, (text, emoji) ->
            if (index % 3 == 0) {
                row = LinearLayout(requireContext()).apply {
                    orientation = LinearLayout.HORIZONTAL
                    layoutParams = LinearLayout.LayoutParams(
                        LinearLayout.LayoutParams.MATCH_PARENT,
                        LinearLayout.LayoutParams.WRAP_CONTENT
                    )
                }
                grid.addView(row)
            }
            val btn = layoutInflater.inflate(com.aphasia.broca.R.layout.item_aac, row, false)
            btn.findViewById<TextView>(com.aphasia.broca.R.id.tvAacEmoji).text = emoji
            btn.findViewById<TextView>(com.aphasia.broca.R.id.tvAacText).text = text
            btn.setOnClickListener { tts.speak(text) }
            (btn.layoutParams as LinearLayout.LayoutParams).apply {
                weight = 1f
                width  = 0
                val m  = (8 * resources.displayMetrics.density).toInt()
                setMargins(m, m, m, m)
            }
            row?.addView(btn)
        }
    }

    override fun onDestroyView() { super.onDestroyView(); _b = null }
}

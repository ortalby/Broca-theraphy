package com.aphasia.broca.util

data class WordStat(
    val att: Int = 0,
    val suc: Int = 0,
    val rep: Int = 0,
    val ease: Float = 2.5f,
    val interval: Int = 0,
    val nextMs: Long = 0L
)

fun sm2Next(stat: WordStat, ok: Boolean): WordStat {
    val now = System.currentTimeMillis()
    val att = stat.att + 1
    val suc = stat.suc + if (ok) 1 else 0
    if (!ok) return stat.copy(att = att, suc = suc, rep = 0, interval = 0, nextMs = now + 10 * 60 * 1000L)
    val rep = stat.rep + 1
    val interval = when (rep) { 1 -> 1; 2 -> 6; else -> (stat.interval * stat.ease).toInt().coerceAtLeast(7) }
    val ease = (stat.ease + 0.05f).coerceAtLeast(1.3f)
    return WordStat(att = att, suc = suc, rep = rep, ease = ease, interval = interval, nextMs = now + interval * 86400000L)
}
